# true color 지원 (xterm-256color + RGB override)
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

# 설정 리로드
bind r source-file ~/.tmux.conf \; display-message "설정 리로드 완료"
bind C-r source-file ~/.tmux.conf \; display-message "설정 리로드 완료"

# prefix를 C-a로 변경
set-option -g prefix C-a
unbind-key C-b

# 인덱스 1부터 시작
set -g base-index 1
setw -g pane-base-index 1

# 윈도우 삭제/추가 시 번호 자동 재정렬
set -g renumber-windows on

# prefix 전송
bind-key a send-prefix
bind-key C-a send-prefix

# 윈도우 이동
bind-key p previous-window
bind-key C-p previous-window
bind-key n next-window
bind-key C-n next-window

# 패인/세션 관리
bind-key C-x kill-pane
bind-key C-d detach-client

# 윈도우 분할 (현재 경로 유지)
bind-key v split-window -h -c "#{pane_current_path}"
bind-key C-v split-window -h -c "#{pane_current_path}"
bind-key s split-window -v -c "#{pane_current_path}"

# 마지막 윈도우
bind-key m last-window

# vim 스타일 패인 이동
bind h select-pane -L
bind C-h select-pane -L
bind j select-pane -D
bind C-j select-pane -D
bind k select-pane -U
bind C-k select-pane -U
bind l select-pane -R
bind C-l select-pane -R

# 패인 리사이즈
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Catppuccin 테마
set -g @catppuccin_flavor 'mocha'
set -g @catppuccin_window_status_style 'rounded'
set -g @catppuccin_window_flags 'icon'

# vi 모드
setw -g mode-keys vi

# 새 윈도우 (현재 경로 유지)
bind C-c new-window -c "#{pane_current_path}"

# 벨 설정
set-option -g bell-action any
set-option -g visual-bell off

# 메시지 표시 시간
set-option -g display-time 10000

# 윈도우 순서 변경 (포커스 유지)
bind-key -n C-S-Left swap-window -d -t -1
bind-key -n C-S-Right swap-window -d -t +1

# escape 지연 제거
set-option -s escape-time 0

# 다중 클라이언트 시 윈도우 크기 최적화
set-window-option -g aggressive-resize on

# 스크롤백 버퍼 늘리기
set -g history-limit 50000

# 마우스 지원
set -g mouse on

# 포커스 이벤트 (에디터 자동 리로드 등에 필요)
set -g focus-events on

# TPM (Tmux Plugin Manager)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @continuum-restore 'on'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'catppuccin/tmux#v2.1.3'

run '~/.tmux/plugins/tpm/tpm'

# 상태바 (catppuccin 로드 후 설정)
set -g status-left ""
set -g status-right-length 100
set -g status-right "#{E:@catppuccin_status_application} #{E:@catppuccin_status_session} #{E:@catppuccin_status_date_time}"
set -g @catppuccin_date_time_text " %m/%d %H:%M"
